# Beispielkonfiguration – kopieren nach .env

# Datenbank
# Wenn gesetzt, wird PostgreSQL verwendet (z. B. auf Hetzner/Render).
# Wenn leer, fällt die App auf SQLite zurück.
DATABASE_URL=

# Optional: Pfad zur SQLite-Datei (Default: data.db)
# SQLITE_PATH=data.db

# Admin-Login Passwort für den versteckten Admin-Login (Punkt im Logo)
# In Produktion zwingend erforderlich.
ADMIN_PASSWORD=mersch75

# Passwort für die Demo-Seed-Benutzer (lokal: demo123, wenn nicht gesetzt)
# In Produktion bitte setzen oder Seed deaktivieren.
SEED_USER_PASSWORD=demo123

# Sitzungs- und Sicherheits-Secrets (mindestens 32 zufällige Zeichen)
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
