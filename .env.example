# Beispielkonfiguration – kopieren nach .env

# Datenbank
# Wenn gesetzt, wird PostgreSQL verwendet (z. B. auf Hetzner/Render).
# Wenn leer, fällt die App auf SQLite zurück.
DATABASE_URL=

# Optional: Pfad zur SQLite-Datei (Default: data.db)
# SQLITE_PATH=data.db

# Admin-Login Passwort für den versteckten Admin-Login (Punkt im Logo)
# In Produktion zwingend erforderlich.
ADMIN_PASSWORD=mersch75

# Passwort für die Demo-Seed-Benutzer (lokal: demo123, wenn nicht gesetzt)
# In Produktion bitte setzen oder Seed deaktivieren.
SEED_USER_PASSWORD=demo123

# Sitzungs- und Sicherheits-Secrets (mindestens 32 zufällige Zeichen)
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production

# ─── Produktion (Hetzner) ───
# NODE_ENV=production
# PORT=3000
# HOST=127.0.0.1  # hinter Nginx: 127.0.0.1, direkt: 0.0.0.0

# Erlaubte Origins für CORS (Komma-getrennt)
# WEBSITE_ORIGIN=https://manager.mersch75.lu,https://mersch75.lu

# Öffentliche Basis-URL (für E-Mail-Links etc.)
# PUBLIC_BASE_URL=https://manager.mersch75.lu

# ─── API-Token System ───
# Tokens werden über /api/admin/tokens verwaltet (präsident/admin).
# Scopes: read:members, read:events, read:teams, read:announcements, read:statistics, write:announcements
# Verwendung: Authorization: Token <64-char hex token>
# Beispiel:
#   curl -H "Authorization: Token <token>" https://manager.mersch75.lu/api/public/events
